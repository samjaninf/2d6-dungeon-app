@implements IDialogContentComponent<ResolveLockedDoorDialogData>
@using c5m._2d6Dungeon
@using c5m._2d6Dungeon.Game
@using System.Text.RegularExpressions
@inject D6Service D6Service
@inject IToastService ToastService

@rendermode InteractiveServer

<div style="min-width: 600px; padding: 10px;">
    <!-- Header -->
    <FluentStack Orientation="Orientation.Horizontal" HorizontalAlignment="HorizontalAlignment.SpaceBetween" VerticalAlignment="VerticalAlignment.Center" Style="margin-bottom: 20px;">
        <FluentLabel Typo="Typography.H3">Resolve Locked Door (@Content.Direction)</FluentLabel>
        <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="5">
            @if (Content.Exit.IsLocked)
            {
                <FluentBadge Appearance="Appearance.Accent">LOCKED</FluentBadge>
            }
            else
            {
                <FluentBadge Style="background-color: #2E5A2E; color: white;">UNLOCKED</FluentBadge>
            }

            @if (Content.Exit.IsDamaged)
            {
                <FluentBadge Style="background-color: #7C3AED; color: white;">LOCK DAMAGED</FluentBadge>
            }
        </FluentStack>
    </FluentStack>

    <FluentGrid Spacing="3">
        <!-- Column 1: Lockpicking -->
        <FluentGridItem XS="12" SM="6">
            <FluentCard Style="height: 100%; min-height: 380px;">
                <FluentStack Orientation="Orientation.Vertical" VerticalGap="15">
                    <FluentLabel Typo="Typography.H4">
                        <FluentIcon Value="@(new Icons.Regular.Size20.LockClosed())" Color="@Color.Accent" Slot="start" />
                        Lockpicking
                    </FluentLabel>

                    @if (Content.Exit.IsDamaged)
                    {
                        <div style="background-color: rgba(124, 58, 237, 0.1); border-left: 4px solid #7C3AED; padding: 12px; border-radius: 4px; margin-bottom: 10px;">
                            <FluentLabel Color="@Color.Custom" CustomColor="#7C3AED" Weight="FontWeight.Bold">Lock is Damaged</FluentLabel>
                            <FluentLabel Typo="Typography.Body">The lock mechanism is permanently jammed and cannot be picked. You must wait for a patrol to bypass the door.</FluentLabel>
                        </div>
                    }
                    else if (Content.Exit.LockQuality == null)
                    {
                        <!-- Step 1: Define Lock Quality -->
                        <FluentLabel Typo="Typography.Body">Roll to define the door's lock quality before picking it.</FluentLabel>
                        
                        <FluentNumberField @bind-Value="Content.Exit.LockModifier" Label="Lock Modifier:" Style="width: 120px;" />
                        
                        <FluentButton Appearance="Appearance.Accent" OnClick="RollLockQuality" IconStart="@(new Icons.Regular.Size16.Cube())">
                            Roll Lock Quality
                        </FluentButton>

                        @if (qualityDiceResult.PrimaryDice > 0)
                        {
                            <div style="margin-top: 10px; text-align: center;">
                                <Dice color="Dice.DiceColor.red" size="Dice.DiceSize.regular" face="@qualityDiceResult.PrimaryDice" Animate="true" />
                                <Dice color="Dice.DiceColor.purple" size="Dice.DiceSize.regular" face="@qualityDiceResult.SecondaryDice" Animate="true" />
                                <div style="margin-top: 8px;">
                                    <FluentLabel Typo="Typography.Body" Weight="FontWeight.Bold">
                                        Quality: @qualityDiceResult.PrimaryDice + @qualityDiceResult.SecondaryDice @(Content.Exit.LockModifier != 0 ? $"{(Content.Exit.LockModifier > 0 ? "+" : "")}{Content.Exit.LockModifier}" : "") = @Content.Exit.LockQuality
                                    </FluentLabel>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <!-- Step 2: Perform Lockpicking -->
                        <div style="background-color: var(--neutral-fill-subtle-rest); padding: 10px; border-radius: 4px;">
                            <FluentLabel Typo="Typography.Body" Weight="FontWeight.Bold">Lock Quality: @Content.Exit.LockQuality</FluentLabel>
                            <FluentLabel Typo="Typography.Body" Size="DesignTokenSize.Small">Beat this number to unlock the door.</FluentLabel>
                        </div>

                        <FluentSelect TOption="string"
                                      Value="@selectedKitId"
                                      ValueChanged="@OnKitSelectedIdChanged"
                                      Label="Select Lockpick Kit:"
                                      Style="width: 100%;">
                            <FluentOption Value="no-kit">No Kit (+0)</FluentOption>
                            <FluentOption Value="custom">Custom Kit...</FluentOption>
                            @for (int i = 0; i < parsedKits.Count; i++)
                            {
                                <FluentOption Value="@i.ToString()">@parsedKits[i].DisplayText</FluentOption>
                            }
                        </FluentSelect>

                        @if (showCustomModifier)
                        {
                            <FluentNumberField @bind-Value="customModifier" 
                                               @bind-Value:after="OnCustomModifierChanged"
                                               Label="Custom Kit Modifier:" 
                                               Style="width: 120px;" />
                        }

                        <div style="background-color: var(--neutral-fill-subtle-rest); padding: 10px; border-radius: 4px; font-size: 13px;">
                            <div><strong>Precision Modifier:</strong> +@Content.Adventure.Adventurer.Precision</div>
                            <div><strong>Kit Modifier:</strong> +@kitModifier</div>
                            <div><strong>Total Modifier:</strong> +@(Content.Adventure.Adventurer.Precision + kitModifier)</div>
                        </div>

                        <FluentButton Appearance="Appearance.Accent" OnClick="RollToPick" IconStart="@(new Icons.Regular.Size16.Key())" Disabled="lockpickingAttempted">
                            Roll to Pick
                        </FluentButton>

                        @if (pickDiceResult.PrimaryDice > 0)
                        {
                            <div style="margin-top: 10px; text-align: center;">
                                <Dice color="Dice.DiceColor.red" size="Dice.DiceSize.regular" face="@pickDiceResult.PrimaryDice" Animate="true" />
                                <Dice color="Dice.DiceColor.purple" size="Dice.DiceSize.regular" face="@pickDiceResult.SecondaryDice" Animate="true" />
                                <div style="margin-top: 8px;">
                                    <FluentLabel Typo="Typography.Body" Weight="FontWeight.Bold" Color="@(pickSuccess ? Color.Success : Color.Error)">
                                        @pickResultText
                                    </FluentLabel>
                                    <FluentLabel Typo="Typography.Body" Size="DesignTokenSize.Small">
                                        Roll: @pickDiceResult.PrimaryDice + @pickDiceResult.SecondaryDice + @Content.Adventure.Adventurer.Precision (Precision) + @kitModifier (Kit) = @pickTotal
                                    </FluentLabel>
                                </div>
                            </div>
                        }

                        @if (pickSuccess)
                        {
                            <FluentButton Appearance="Appearance.Lightweight" OnClick="CloseDialog" Style="margin-top: 10px;">Proceed</FluentButton>
                        }
                    }
                </FluentStack>
            </FluentCard>
        </FluentGridItem>

        <!-- Column 2: Wait for Patrol -->
        <FluentGridItem XS="12" SM="6">
            <FluentCard Style="height: 100%; min-height: 380px;">
                <FluentStack Orientation="Orientation.Vertical" VerticalGap="15">
                    <FluentLabel Typo="Typography.H4">
                        <FluentIcon Value="@(new Icons.Regular.Size20.Clock())" Color="@Color.Accent" Slot="start" />
                        Wait for Patrol
                    </FluentLabel>

                    <FluentLabel Typo="Typography.Body">Waiting costs resources but allows you to bypass the door by waiting for a patrol to open it.</FluentLabel>

                    <div style="background-color: var(--neutral-fill-subtle-rest); padding: 12px; border-radius: 4px;">
                        <FluentLabel Typo="Typography.Body" Weight="FontWeight.Bold">Select Rest Option:</FluentLabel>
                        <FluentRadioGroup Name="rations" @bind-Value="rationChoice">
                            <FluentRadio Value="@("use")" Disabled="@(!canUseRations)">
                                Use 1 Ration (Consumes 1 ration, heals +2 HP)
                                <FluentBadge Style="margin-left: 5px;">Rations: @Content.Adventure.Adventurer.Rations</FluentBadge>
                            </FluentRadio>
                            <FluentRadio Value="@("none")">
                                Suffer damage (No ration used, suffer -@(2 * Content.Adventure.Adventurer.Level) HP)
                            </FluentRadio>
                        </FluentRadioGroup>
                    </div>

                    <FluentButton Appearance="Appearance.Accent" OnClick="RollPatrol" IconStart="@(new Icons.Regular.Size16.Clock())" Disabled="patrolAttempted">
                        Wait for Patrol
                    </FluentButton>

                    @if (patrolDiceResult.PrimaryDice > 0)
                    {
                        <div style="margin-top: 10px; text-align: center;">
                            <Dice color="Dice.DiceColor.red" size="Dice.DiceSize.regular" face="@patrolDiceResult.PrimaryDice" Animate="true" />
                            <Dice color="Dice.DiceColor.purple" size="Dice.DiceSize.regular" face="@patrolDiceResult.SecondaryDice" Animate="true" />
                            <div style="margin-top: 8px; text-align: left; padding: 10px; background-color: var(--neutral-fill-subtle-rest); border-radius: 4px;">
                                <div style="font-weight: bold; margin-bottom: 5px; color: var(--accent-fill-rest);">
                                    Patrol Roll: @(patrolDiceResult.PrimaryDice + patrolDiceResult.SecondaryDice)
                                </div>
                                <div style="font-size: 13px; line-height: 1.4; margin-bottom: 5px;">
                                    @patrolResultText
                                </div>
                                <div style="font-size: 12px; color: var(--neutral-foreground-hint); border-top: 1px solid var(--neutral-stroke-rest); padding-top: 5px; margin-top: 5px;">
                                    @patrolLog
                                </div>
                            </div>
                        </div>
                    }

                    @if (showPatrolFinishedButton)
                    {
                        <FluentButton Appearance="Appearance.Accent" OnClick="CloseDialog" Style="margin-top: 10px; width: 100%;">
                            @(Content.CombatInitiated ? "Enter Combat" : "Proceed")
                        </FluentButton>
                    }
                </FluentStack>
            </FluentCard>
        </FluentGridItem>
    </FluentGrid>
</div>

@code {
    [Parameter]
    public ResolveLockedDoorDialogData Content { get; set; } = default!;

    [CascadingParameter]
    public FluentDialog Dialog { get; set; } = default!;

    private DiceResult qualityDiceResult = new DiceResult { PrimaryDice = 0, SecondaryDice = 0 };
    private DiceResult pickDiceResult = new DiceResult { PrimaryDice = 0, SecondaryDice = 0 };
    private DiceResult patrolDiceResult = new DiceResult { PrimaryDice = 0, SecondaryDice = 0 };

    private List<LockpickKit> parsedKits = new();
    private LockpickKit? selectedKit;
    private string selectedKitId = "no-kit";
    private int kitModifier = 0;
    private bool showCustomModifier = false;
    private int customModifier = 0;

    private bool lockpickingAttempted = false;
    private bool pickSuccess = false;
    private int pickTotal = 0;
    private string pickResultText = string.Empty;

    private string rationChoice = "none";
    private bool canUseRations => Content.Adventure.Adventurer.Rations >= 1;
    private bool patrolAttempted = false;
    private string patrolResultText = string.Empty;
    private string patrolLog = string.Empty;
    private bool showPatrolFinishedButton = false;

    protected override void OnInitialized()
    {
        parsedKits = ParseLockpickKits(Content.Adventure.Adventurer.SmallItems);
        if (canUseRations)
        {
            rationChoice = "use";
        }
        else
        {
            rationChoice = "none";
        }
    }

    private class LockpickKit
    {
        public string RawText { get; set; } = string.Empty;
        public int Modifier { get; set; }
        public int Uses { get; set; }
        public string DisplayText { get; set; } = string.Empty;
    }

    private List<LockpickKit> ParseLockpickKits(string? smallItems)
    {
        var kits = new List<LockpickKit>();
        if (string.IsNullOrWhiteSpace(smallItems)) return kits;

        // Matches Lock Pick +1 (3) or Lock Pick -1 (2) or Lock Pick 0 (1) or Lock Pick +0 (3)
        var regex = new Regex(@"Lock\s+Pick\s+([+-]?\d+)\s*\((\d+)\)", RegexOptions.IgnoreCase);
        var matches = regex.Matches(smallItems);
        foreach (Match match in matches)
        {
            if (match.Success)
            {
                int modifier = int.Parse(match.Groups[1].Value);
                int uses = int.Parse(match.Groups[2].Value);
                kits.Add(new LockpickKit
                {
                    RawText = match.Value,
                    Modifier = modifier,
                    Uses = uses,
                    DisplayText = $"Lock Pick {(modifier >= 0 ? "+" : "")}{modifier} ({uses} uses)"
                });
            }
        }
        return kits;
    }

    private void OnKitSelectedIdChanged(string val)
    {
        selectedKitId = val;
        if (val == "no-kit")
        {
            selectedKit = null;
            showCustomModifier = false;
            kitModifier = 0;
        }
        else if (val == "custom")
        {
            selectedKit = null;
            showCustomModifier = true;
            kitModifier = customModifier;
        }
        else
        {
            showCustomModifier = false;
            if (int.TryParse(val, out int idx) && idx >= 0 && idx < parsedKits.Count)
            {
                selectedKit = parsedKits[idx];
                kitModifier = selectedKit.Modifier;
            }
        }
    }

    private void OnCustomModifierChanged()
    {
        if (selectedKitId == "custom")
        {
            kitModifier = customModifier;
        }
    }

    private void RollLockQuality()
    {
        qualityDiceResult = DiceResult.Roll2Dice();
        Content.Exit.LockQuality = qualityDiceResult.PrimaryDice + qualityDiceResult.SecondaryDice + Content.Exit.LockModifier;
    }

    private async Task RollToPick()
    {
        if (Content.Exit.LockQuality == null) return;

        lockpickingAttempted = true;
        pickDiceResult = DiceResult.Roll2Dice();
        
        int precision = Content.Adventure.Adventurer.Precision;
        pickTotal = pickDiceResult.PrimaryDice + pickDiceResult.SecondaryDice + precision + kitModifier;

        if (pickTotal >= Content.Exit.LockQuality.Value)
        {
            pickSuccess = true;
            Content.Exit.IsLocked = false;
            Content.Unlocked = true;
            pickResultText = "Success! The lock clicks open.";
            ToastService.ShowToast(ToastIntent.Success, "Door unlocked successfully!");
            await SaveAdventure();
        }
        else
        {
            pickSuccess = false;
            Content.Exit.IsDamaged = true;
            pickResultText = "Failure! The lock jams and is permanently damaged.";
            ToastService.ShowToast(ToastIntent.Error, "Failed to pick the lock. It is now damaged.");

            // Decrement uses
            if (selectedKit != null)
            {
                DecrementKitUses(selectedKit);
            }
            await SaveAdventure();
        }
    }

    private void DecrementKitUses(LockpickKit kit)
    {
        var player = Content.Adventure.Adventurer;
        int newUses = kit.Uses - 1;
        if (newUses < 0) newUses = 0;

        string newKitText = $"Lock Pick {(kit.Modifier >= 0 ? "+" : "")}{kit.Modifier} ({newUses})";

        if (!string.IsNullOrEmpty(player.SmallItems))
        {
            int index = player.SmallItems.IndexOf(kit.RawText, StringComparison.OrdinalIgnoreCase);
            if (index != -1)
            {
                player.SmallItems = player.SmallItems.Remove(index, kit.RawText.Length).Insert(index, newKitText);
            }
        }
    }

    private async Task RollPatrol()
    {
        patrolAttempted = true;
        patrolDiceResult = DiceResult.Roll2Dice();
        int rollTotal = patrolDiceResult.PrimaryDice + patrolDiceResult.SecondaryDice;

        var adventurer = Content.Adventure.Adventurer;
        if (rationChoice == "use" && adventurer.Rations >= 1)
        {
            adventurer.Rations--;
            adventurer.HealthPoints += 2;
            patrolLog = $"Used 1 ration to rest (+2 HP). Rations left: {adventurer.Rations}. ";
        }
        else
        {
            adventurer.HealthPoints -= 2 * adventurer.Level;
            patrolLog = $"Waited without rations. Suffered {2 * adventurer.Level} HP damage. ";
        }

        var table = await D6Service.GetTableData("enp2");
        var row = table?.Rows.FirstOrDefault(r => r.Roll == rollTotal.ToString());
        string description = row?.Description ?? "A quiet patrol passes, opening the door for you.";

        patrolResultText = description;

        // Check hostile
        bool isHostile = false;
        string creatureName = "";
        if (description.Contains("Face a GUARD", StringComparison.OrdinalIgnoreCase)) { isHostile = true; creatureName = "GUARD"; }
        else if (description.Contains("Face a THUG", StringComparison.OrdinalIgnoreCase)) { isHostile = true; creatureName = "THUG"; }
        else if (description.Contains("Face an ACOLYTE", StringComparison.OrdinalIgnoreCase)) { isHostile = true; creatureName = "ACOLYTE"; }
        else if (description.Contains("Face an INFERNAL MONK", StringComparison.OrdinalIgnoreCase)) { isHostile = true; creatureName = "INFERNAL MONK"; }
        else if (description.Contains("Face a KNIGHT", StringComparison.OrdinalIgnoreCase)) { isHostile = true; creatureName = "KNIGHT"; }

        if (isHostile)
        {
            var creature = await GetCreatureForPatrol(creatureName);
            Content.Adventure.CombatState = new CombatState(adventurer)
            {
                Creature = creature,
                TurnCounter = 0
            };
            Content.Adventure.CombatState.CombatActions.Add($"Encountered hostile {creatureName} patrol while waiting!");
            
            Content.Exit.IsLocked = false;
            Content.CombatInitiated = true;
            Content.Unlocked = true;
            
            patrolLog += $"Hostile encounter initiated! Fighting {creatureName}.";
            ToastService.ShowToast(ToastIntent.Warning, $"Hostile patrol: Face a {creatureName}!");
        }
        else
        {
            Content.Exit.IsLocked = false;
            Content.Unlocked = true;
            
            patrolLog += "Non-hostile encounter. The door is now unlocked.";
            ToastService.ShowToast(ToastIntent.Success, "A non-hostile patrol bypassed the door and unlocked it!");
        }

        await SaveAdventure();
        showPatrolFinishedButton = true;
    }

    private async Task<Creature> GetCreatureForPatrol(string name)
    {
        var creatures = await D6Service.GetCreatures();
        var match = creatures.First(c => c.name.Equals(name, StringComparison.OrdinalIgnoreCase));
        return match;
    }
    

    private async Task SaveAdventure()
    {
        await D6Service.AdventureSave(Content.Adventure);
    }

    private async Task CloseDialog()
    {
        await Dialog.CloseAsync(Content);
    }
}
